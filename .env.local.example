# Copy to .env.local and fill in.
OPENROUTER_API_KEY=

# Required only if you use voice input. /api/realtime-token mints ephemeral
# session tokens so the browser can stream mic audio to OpenAI's Realtime API
# (gpt-4o-transcribe) over WebRTC. OpenRouter does not proxy audio.
# OPENAI_API_KEY=

# Optional. Used as the HTTP-Referer header for OpenRouter app attribution.
# OPENROUTER_REFERER=http://localhost:3000

# Optional. Override the synthesis/judge model. Defaults to openai/gpt-5.4-mini.
# MODEL_JUDGE=openai/gpt-5.4-mini

# Per-stage models are configured in lib/providers.ts (STAGES).
#
# Defaults:
#   Stage 1 (Instant, streamed):
#     openai/gpt-5.4-mini @ minimal
#   Stage 2 (Reasoned, parallel @ medium, ~1 min):
#     openai/gpt-5.5, anthropic/claude-opus-4.7,
#     google/gemini-3.1-pro-preview, x-ai/grok-4.20
#   Stage 3 (Deep, parallel @ high, slower):
#     openai/gpt-5.5, anthropic/claude-opus-4.7,
#     google/gemini-3.1-pro-preview, x-ai/grok-4.20
